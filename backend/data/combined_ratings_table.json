{
  "metadata": {
    "source": "38 CFR Part 4 - Combined Ratings Table",
    "formula": "combined = 1 - ((1-r1) * (1-r2) * ... * (1-rN)), then round to nearest 10",
    "note": "VA uses 'whole person' math. Ratings are applied in descending order. Final result rounds to nearest 10%.",
    "rounding_rule": "Values ending in 1-4 round down, 5-9 round up to nearest 10"
  },
  "formula_explanation": {
    "step1": "Sort all individual ratings from highest to lowest",
    "step2": "Apply each rating against the remaining 'whole person'",
    "step3": "combined_decimal = 1 - product_of_all_(1 - rating_decimal)",
    "step4": "Multiply by 100 to get percentage",
    "step5": "Round to nearest 10 (5 rounds up)",
    "example_1": {
      "ratings": [50, 30],
      "calculation": "1 - (0.50 * 0.70) = 1 - 0.35 = 0.65 = 65% -> rounds to 70%",
      "result": 70
    },
    "example_2": {
      "ratings": [70, 30],
      "calculation": "1 - (0.30 * 0.70) = 1 - 0.21 = 0.79 = 79% -> rounds to 80%",
      "result": 80
    },
    "example_3": {
      "ratings": [50, 40, 20],
      "calculation": "1 - (0.50 * 0.60 * 0.80) = 1 - 0.24 = 0.76 = 76% -> rounds to 80%",
      "result": 80
    },
    "example_4": {
      "ratings": [70, 50, 30, 10],
      "calculation": "1 - (0.30 * 0.50 * 0.70 * 0.90) = 1 - 0.0945 = 0.9055 = 91% -> rounds to 90%",
      "result": 90
    }
  },
  "tdiu_thresholds": {
    "single_condition": {
      "minimum_rating": 60,
      "note": "One condition rated at 60%+ may qualify for TDIU under 38 CFR 4.16(a)"
    },
    "multiple_conditions": {
      "minimum_combined": 70,
      "minimum_single": 40,
      "note": "Combined 70%+ with at least one condition at 40%+ qualifies under 38 CFR 4.16(a)"
    },
    "extraschedular": {
      "note": "Even if thresholds not met, TDIU possible under 38 CFR 4.16(b) if veteran is unemployable"
    }
  },
